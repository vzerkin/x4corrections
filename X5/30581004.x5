     ,"ERR-ANALYS":[
	{"x4pointer":" "
	 ,"x4code":{"header":"ERR-T"
	     ,"headerHelp":"Total uncertainty (1-Sigma)"}
	,"x4freetext":[" Error comprises statistical and"
		,"                                systematical errors."
		," *Systematic errors contain the following uncertainties"
		," 1)of Ge(Li) detector efficiencies,   up to about 3%"
		," 2)of the cross-section of reference, up to  5%,"
		," 3)caused by fluctuation of n-flux,   less than 1%"
		," 4)of gamma attenuation in sample,    up to about 0.5%"
		," 5)of nonuniformity of d-beam on tritium target,"
		,"                                 estimate not possible."]
	}
      ]
