	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"CSICR", "dict":"DETECTOR", "idict":22,"hlp":"Cesium-Iodide crystal"}]
	,"x4freetext":["Neutron flux was controlled during irradiation by"
		,"counting the protons recoiled by the incident neutrons"
		,"from a polyethylene foil into a CsI(Tl) crystal."]
	}
